{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1.0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["zh", "en"]
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_enabled": true,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      { "type": "repo_releases", "owner": "openai", "repo": "openai-python", "enabled": true },
      { "type": "repo_releases", "owner": "anthropics", "repo": "anthropic-sdk-python", "enabled": true },
      { "type": "repo_releases", "owner": "microsoft", "repo": "autogen", "enabled": true },
      { "type": "repo_releases", "owner": "langchain-ai", "repo": "langchain", "enabled": true },
      { "type": "repo_releases", "owner": "run-llama", "repo": "llama_index", "enabled": true },
      { "type": "repo_releases", "owner": "modelcontextprotocol", "repo": "python-sdk", "enabled": true }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 80
    },
    "rss": [
      { "name": "OpenAI Blog", "url": "https://openai.com/news/rss.xml", "enabled": true, "category": "ai-news" },
      { "name": "Anthropic News", "url": "https://www.anthropic.com/news/rss.xml", "enabled": true, "category": "ai-news" },
      { "name": "Google AI Blog", "url": "https://blog.google/technology/ai/rss/", "enabled": true, "category": "ai-news" },
      { "name": "Hugging Face Blog", "url": "https://huggingface.co/blog/feed.xml", "enabled": true, "category": "ai-tools" },
      { "name": "Simon Willison", "url": "https://simonwillison.net/atom/everything/", "enabled": true, "category": "ai-tools" },
      { "name": "The Batch - DeepLearning.AI", "url": "https://www.deeplearning.ai/the-batch/feed/", "enabled": true, "category": "ai-news" },
      { "name": "Papers with Code", "url": "https://paperswithcode.com/rss", "enabled": true, "category": "machine-learning" },
      { "name": "GitHub Blog", "url": "https://github.blog/feed/", "enabled": true, "category": "developer-tools" },
      { "name": "InfoQ AI/ML", "url": "https://feed.infoq.com/ai-ml-data-eng/", "enabled": true, "category": "ai-news" }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        { "subreddit": "MachineLearning", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 15, "min_score": 50 },
        { "subreddit": "LocalLLaMA", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 15, "min_score": 40 },
        { "subreddit": "OpenAI", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 10, "min_score": 30 }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": true,
      "channels": [
        { "channel": "OpenAI", "enabled": false, "fetch_limit": 20 }
      ]
    },
    "twitter": {
      "enabled": false,
      "mode": "apify",
      "users": ["OpenAI", "AnthropicAI", "GoogleDeepMind", "karpathy"],
      "fetch_limit": 20,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5,
      "apify_token_env": "APIFY_TOKEN"
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript", "Rust"],
      "keywords": ["ai", "llm", "agent", "rag", "mcp", "inference", "model"],
      "min_stars": 10,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 6.5,
    "time_window_hours": 24,
    "max_items": 20,
    "category_groups": {
      "ai": {
        "name": "AI / Machine Learning",
        "limit": 8,
        "categories": ["ai-news", "ai-tools", "machine-learning"]
      },
      "dev": {
        "name": "Developer Tools / Open Source",
        "limit": 6,
        "categories": ["developer-tools", "open-source"]
      }
    },
    "default_group": "other",
    "default_group_limit": 6
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": ["zh"],
    "request_body": {
      "text": "Horizon #{date} #{message_title}\n\n#{summary?limit=3000&split=---}"
    },
    "headers": ""
  }
}
