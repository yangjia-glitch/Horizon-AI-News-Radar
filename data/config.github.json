{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1.0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["zh", "en"]
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_enabled": true,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "",
    "sender_name": "Horizon Trade Radar",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": false,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "rss": [
      {
        "name": "WTO News",
        "url": "https://www.wto.org/english/news_e/news_e.rss",
        "enabled": true,
        "category": "trade-policy"
      },
      {
        "name": "International Trade Administration",
        "url": "https://www.trade.gov/rss.xml",
        "enabled": true,
        "category": "export-compliance"
      },
      {
        "name": "Global Trade Magazine",
        "url": "https://www.globaltrademag.com/feed/",
        "enabled": true,
        "category": "global-trade"
      },
      {
        "name": "SupplyChainBrain - All Articles",
        "url": "https://www.supplychainbrain.com/rss/articles",
        "enabled": true,
        "category": "supply-chain"
      },
      {
        "name": "Supply Chain Dive",
        "url": "https://www.supplychaindive.com/feeds/news/",
        "enabled": true,
        "category": "supply-chain"
      },
      {
        "name": "FreightWaves News",
        "url": "https://www.freightwaves.com/news/feed",
        "enabled": true,
        "category": "shipping-logistics"
      },
      {
        "name": "WorldTradeLaw - International Economic Law and Policy Blog",
        "url": "https://ielp.worldtradelaw.net/atom.xml",
        "enabled": true,
        "category": "trade-law"
      },
      {
        "name": "Global Trade This Week Podcast",
        "url": "https://feed.podbean.com/uptimelogistics/feed.xml",
        "enabled": true,
        "category": "global-trade"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "supplychain",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 20
        },
        {
          "subreddit": "logistics",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 10
        },
        {
          "subreddit": "internationaltrade",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 10,
          "min_score": 5
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "twitter": {
      "enabled": false,
      "mode": "apify",
      "users": ["wto", "UNCTAD", "TradeGov"],
      "fetch_limit": 20,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5,
      "apify_token_env": "APIFY_TOKEN"
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": ["All"],
      "keywords": [],
      "min_stars": 10,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 6.5,
    "time_window_hours": 24,
    "max_items": 20,
    "category_groups": {
      "trade": {
        "name": "Trade Policy / Tariffs / Compliance",
        "limit": 8,
        "categories": ["trade-policy", "export-compliance", "trade-law"]
      },
      "logistics": {
        "name": "Shipping / Logistics / Supply Chain",
        "limit": 8,
        "categories": ["shipping-logistics", "supply-chain"]
      },
      "global": {
        "name": "Global Trade / Market Signals",
        "limit": 6,
        "categories": ["global-trade"]
      }
    },
    "default_group": "other",
    "default_group_limit": 5
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": ["zh"],
    "request_body": {
      "text": "Horizon 外贸资讯雷达 #{date} #{message_title}\n\n#{summary?limit=3000&split=---}"
    },
    "headers": ""
  }
}
