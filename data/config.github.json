{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1.0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["zh", "en"]
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_enabled": true,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "",
    "sender_name": "Horizon AI Tech Radar",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      { "type": "repo_releases", "owner": "openai", "repo": "openai-python", "enabled": true },
      { "type": "repo_releases", "owner": "openai", "repo": "openai-node", "enabled": true },
      { "type": "repo_releases", "owner": "anthropics", "repo": "anthropic-sdk-python", "enabled": true },
      { "type": "repo_releases", "owner": "anthropics", "repo": "anthropic-sdk-typescript", "enabled": true },
      { "type": "repo_releases", "owner": "modelcontextprotocol", "repo": "python-sdk", "enabled": true },
      { "type": "repo_releases", "owner": "modelcontextprotocol", "repo": "typescript-sdk", "enabled": true },
      { "type": "repo_releases", "owner": "huggingface", "repo": "transformers", "enabled": true },
      { "type": "repo_releases", "owner": "huggingface", "repo": "huggingface_hub", "enabled": true },
      { "type": "repo_releases", "owner": "langchain-ai", "repo": "langchain", "enabled": true },
      { "type": "repo_releases", "owner": "run-llama", "repo": "llama_index", "enabled": true },
      { "type": "repo_releases", "owner": "vllm-project", "repo": "vllm", "enabled": true }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 40,
      "min_score": 80
    },
    "rss": [
      { "name": "OpenAI News", "url": "https://openai.com/news/rss.xml", "enabled": true, "category": "official-ai" },
      { "name": "Google AI Blog", "url": "https://blog.google/technology/ai/rss/", "enabled": true, "category": "official-ai" },
      { "name": "Hugging Face Blog", "url": "https://huggingface.co/blog/feed.xml", "enabled": true, "category": "open-source-ai" },
      { "name": "Simon Willison", "url": "https://simonwillison.net/atom/everything/", "enabled": true, "category": "ai-engineering" },
      { "name": "Latent Space", "url": "https://www.latent.space/feed", "enabled": true, "category": "ai-engineering" },
      { "name": "Import AI - Jack Clark", "url": "https://jack-clark.net/feed/", "enabled": true, "category": "ai-research" },
      { "name": "The Batch - DeepLearning.AI", "url": "https://www.deeplearning.ai/the-batch/feed", "enabled": true, "category": "ai-news" },
      { "name": "量子位", "url": "https://www.qbitai.com/feed", "enabled": true, "category": "zh-ai-news" }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        { "subreddit": "MachineLearning", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 20, "min_score": 50 },
        { "subreddit": "LocalLLaMA", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 20, "min_score": 40 },
        { "subreddit": "OpenAI", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 15, "min_score": 30 },
        { "subreddit": "ClaudeAI", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 15, "min_score": 20 }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "twitter": {
      "enabled": false,
      "mode": "apify",
      "users": ["OpenAI", "AnthropicAI", "GoogleDeepMind", "huggingface", "simonw"],
      "fetch_limit": 20,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5,
      "apify_token_env": "APIFY_TOKEN"
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript", "Rust", "Go", "Jupyter Notebook"],
      "keywords": ["ai", "llm", "agent", "mcp", "rag", "inference", "transformer", "diffusion", "embedding", "vector", "cuda", "vllm", "mlx"],
      "min_stars": 10,
      "max_items": 40
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": 25,
    "category_groups": {
      "official": {
        "name": "Official AI Labs / Product Updates",
        "limit": 8,
        "categories": ["official-ai", "ai-news"]
      },
      "engineering": {
        "name": "AI Engineering / Agents / MCP",
        "limit": 8,
        "categories": ["ai-engineering", "open-source-ai"]
      },
      "research": {
        "name": "AI Research / Papers / Trends",
        "limit": 6,
        "categories": ["ai-research", "machine-learning"]
      },
      "china": {
        "name": "Chinese AI News",
        "limit": 5,
        "categories": ["zh-ai-news"]
      }
    },
    "default_group": "other",
    "default_group_limit": 8
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": ["zh"],
    "request_body": {
      "text": "Horizon AI 技术雷达 #{date} #{message_title}\n\n#{summary?limit=3000&split=---}"
    },
    "headers": ""
  }
}
